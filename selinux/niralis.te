policy_module(niralis, 1.0.0)

########################################
# Types and entrypoint

type niralis_t;
type niralis_exec_t;
init_daemon_domain(niralis_t, niralis_exec_t)
# The system manager runs services in system_r. Keep the dedicated Niralis
# domain available only to that system role until pam_selinux selects the final
# authenticated user role for the graphical exec.
role system_r types niralis_t;

# systemd starts the trusted setpriv wrapper in unconfined_service_t. When that
# wrapper execs the daemon's dedicated entrypoint, transition immediately into
# niralis_t; do not leave the daemon or its worker in the generic service
# domain.
gen_require(`
    type unconfined_service_t;
')
domain_auto_trans(unconfined_service_t, niralis_exec_t, niralis_t)

# niralisd, worker and session child currently share niralis_t. Helper
# execution therefore occurs without a domain transition.
can_exec(niralis_t, niralis_exec_t)

type niralis_etc_t;
files_config_file(niralis_etc_t)

type niralis_var_run_t;
files_pid_file(niralis_var_run_t)

# Persistent supervisor-owned recovery ledger. Keep it distinct from the
# runtime socket/lock tree so a compromised session cannot inherit a broad
# writable state label and so reboot-surviving records have an explicit type.
type niralis_var_lib_t;
files_type(niralis_var_lib_t)

########################################
# Niralis-owned configuration and runtime state

manage_dirs_pattern(niralis_t, niralis_etc_t, niralis_etc_t)
manage_files_pattern(niralis_t, niralis_etc_t, niralis_etc_t)
manage_dirs_pattern(niralis_t, niralis_var_run_t, niralis_var_run_t)
manage_files_pattern(niralis_t, niralis_var_run_t, niralis_var_run_t)
manage_sock_files_pattern(niralis_t, niralis_var_run_t, niralis_var_run_t)
manage_dirs_pattern(niralis_t, niralis_var_lib_t, niralis_var_lib_t)
manage_files_pattern(niralis_t, niralis_var_lib_t, niralis_var_lib_t)
# The launcher and its authenticated worker share niralis_t but use a private,
# lifecycle-correlated Unix stream socket for the pre-Started acknowledgement.
# Limit connectto to a server socket owned by the same SELinux domain; pathname
# access remains restricted to Niralis-owned runtime state above.
allow niralis_t self:unix_stream_socket connectto;

########################################
# Explicitly required service operations

auth_use_nsswitch(niralis_t)
auth_use_pam(niralis_t)
auth_domtrans_pam_timestamp(niralis_t)
systemd_dbus_chat_logind(niralis_t)
# The worker asks the system manager to create and later stop only its
# Niralis-owned transient payload scope. This interface limits D-Bus messaging
# to init_t (PID 1); it does not grant generic access to other system services.
init_dbus_chat(niralis_t)
# systemd applies separate SELinux method checks to StartTransientUnit and
# StopUnit. Grant only those manager operations; no unit-file management,
# enablement, reboot, reload, or generic service permissions are included.
init_start(niralis_t)
init_stop(niralis_t)
# The startup inventory asks systemd for read-only status of its unit list so
# unknown Niralis payload scopes can be detected before login is enabled. Use
# the reference-policy interface for all unit-file labels; this grants status
# only, never start/stop/reload or unit-file management.
systemd_status_all_unit_files(niralis_t)
# pam_systemd registers the session through logind's private runtime socket.
# This grants only the socket-file write and server connect permissions.
systemd_logind_stream_connect(niralis_t)

# sd-login APIs such as sd_seat_can_graphical() read logind runtime
# state from /run/systemd, including /run/systemd/seats/seat0.
systemd_login_read_pid_files(niralis_t)

# pam_selinux resolves the PAM user through /etc/selinux/{config,seusers}
# and optional per-user entries under /etc/selinux/targeted/logins, then
# selects an ordered session context from default_contexts.
seutil_read_config(niralis_t)
seutil_read_login_config(niralis_t)
seutil_read_default_contexts(niralis_t)
# pam_selinux validates the final context built from default_contexts before
# preparing the session exec context.
selinux_validate_context(niralis_t)
# pam_selinux computes the per-user label for the allocated virtual terminal.
selinux_compute_relabel_context(niralis_t)
# The session child applies PAM's pending exec context, then explicitly
# transitions through /usr/bin/niri (bin_t) into the authenticated user domain.
userdom_bin_spec_domtrans_unpriv_users(niralis_t)
# On this targeted policy, pam_selinux maps the local account to unconfined_t,
# which is not an unpriv_userdomain member. Keep that explicit transition
# narrow and retain only the inherited descriptor relationships it needs.
gen_require(`
    type unconfined_t;
')
corecmd_bin_spec_domtrans(niralis_t, unconfined_t)
# pam_selinux selected unconfined_u:unconfined_r:unconfined_t for this local
# account.  The child supplies that complete context with setexeccon() before
# execve(), so RBAC checks the final process type, rather than Niri's bin_t
# file label.
gen_require(`
    role system_r;
    role unconfined_r;
')
role_transition system_r unconfined_t unconfined_r;
# The final context changes both SELinux user and role.  These are the
# reference-policy constraint exemptions used by login programs; the target
# remains a normal user-domain target selected by pam_selinux.
domain_subj_id_change_exemption(niralis_t)
domain_role_change_exemption(niralis_t)
# After exec, verify the kernel-reported context of the freshly-created
# PAM user process through /proc/<pid>/attr/current.  The reference policy
# exposes this verification access for user domains as a single interface.
userdom_read_all_users_state(niralis_t)
userdom_getattr_all_users(niralis_t)
# getpidcon() traverses procfs on kernels that expose process entries through
# pidfs, and only needs filesystem metadata access for that verification.
fs_getattr_pidfs(niralis_t)
# Linux gates cross-UID reads of /proc/<pid>/attr/current through its ptrace
# access check.  CAP_SYS_PTRACE satisfies that DAC check only; Niralis still
# receives no SELinux process:ptrace permission.
allow niralis_t self:capability sys_ptrace;
# getpidcon() performs the kernel DAC checks while reading the freshly
# exec'd process context. Keep these permissions self-directed and limited to
# the worker domain; they do not grant ptrace or access to arbitrary payload
# files.
allow niralis_t self:capability { dac_read_search dac_override };
allow niralis_t self:process getattr;
# The worker supervises only the process group it created: SIGTERM first,
# then SIGKILL after its bounded grace period.  User domains have distinct
# Unix UIDs, so the kernel also requires CAP_KILL for that supervision.
userdom_signal_all_users(niralis_t)
userdom_kill_all_users(niralis_t)
allow niralis_t self:capability kill;
allow unconfined_t niralis_t:fd use;
allow unconfined_t niralis_t:fifo_file rw_file_perms;
allow unconfined_t niralis_t:process sigchld;

# sd_pid_get_session() reads the worker's dynamically-labelled
# /proc/<pid>/cgroup and PID 1's cgroup to resolve the namespace root.
read_files_pattern(niralis_t, niralis_t, niralis_t)
init_read_state(niralis_t)
# A3.4 emergency recovery proves only its invocation-pinned payload boundary
# empty. That proof reads cgroup.events/cgroup.procs and lists child cgroups;
# it never writes, creates, or moves any cgroup. Use the reference-policy
# read/list interfaces rather than a hand-written broad cgroup allow.
fs_list_cgroup_dirs(niralis_t)
fs_read_cgroup_files(niralis_t)

term_use_console(niralis_t)
term_use_unallocated_ttys(niralis_t)
# pam_selinux hands the allocated VT to the authenticated user domain.
term_relabel_unallocated_ttys(niralis_t)
userdom_relabel_user_ttys(niralis_t)
# On session close, pam_selinux restores the owned VT from the authenticated
# user's tty label to tty_device_t. The kernel applies an additional DAC owner
# check at that point; grant only the exact capability observed for this
# restoration, while the SELinux relabel remains limited by the tty rules.
allow niralis_t self:capability fowner;
# A later session attempt may receive the same VT while it still carries the
# PAM user-tty label. Reopen only that user tty type; this does not grant PTY
# or arbitrary device access.
userdom_use_user_ttys(niralis_t)
# The child enters the authenticated account's home before the final exec.
userdom_search_user_home_dirs(niralis_t)
# Before final setexeccon, the child proves connectivity to the existing
# authenticated user's session bus.  It never launches or manages a bus.
userdom_search_user_tmp_dirs(niralis_t)
dbus_write_session_tmp_sock_files(niralis_t)
dbus_stream_connect_session_bus(niralis_t)
dbus_chat_session_bus(niralis_t)

# niralisd sets the IPC socket ownership to root:<greeter primary gid>.
# The kernel also checks FSETID while changing that socket's ownership.
allow niralis_t self:capability { chown fsetid };
# The dedicated session child clears supplementary groups, then drops to the
# PAM-authenticated gid and uid before any user-controlled execution.
allow niralis_t self:capability { setgid setuid };
# The dedicated session child invokes capset only after the verified
# setgroups -> setgid -> setuid drop, to clear every effective, permitted,
# inheritable, and ambient capability before user execution.  This permission
# authorizes that self-directed kernel operation; it grants no Linux
# capability and the child rejects a non-empty post-drop proof.
allow niralis_t self:process setcap;
# Required for TIOCSCTTY on the dedicated PAM-labelled virtual terminal.
allow niralis_t self:capability sys_tty_config;

# The child serializes the fixed, non-secret exec-plan handoff into a sealed
# memfd, then the fixed probe reads that same inherited descriptor.  Permit
# only those read/write operations on the anonymous tmpfs file; neither side
# opens a path in tmpfs and the descriptor is sealed before final exec.
allow niralis_t tmpfs_t:file { read write };

########################################
# pam_selinux provides the final user context. niralis_t may request it only
# for a user-domain exec after the Unix credential drop; it never runs the
# privileged child in that target context.

allow niralis_t niralis_t:process { setexec setsched };
# pam_selinux sets the key-creation context alongside the pending exec
# context; the reference policy exposes no narrower interface for it.
allow niralis_t niralis_t:process setkeycreate;
userdom_transition_login_userdomain(niralis_t)
