auth     include common-auth
account  include common-account
password include common-password
# Niralis owns a graphical logind session. Do not include common-session here:
# on openSUSE it makes pam_systemd optional, which can defer a missing logind
# session into an opaque missing-XDG-environment failure.
session  required pam_selinux.so close
session  required pam_selinux.so open
session  required pam_limits.so
session  required pam_systemd.so
session  required pam_unix.so
session  optional pam_umask.so
session  optional pam_env.so
